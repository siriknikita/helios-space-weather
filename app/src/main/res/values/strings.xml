<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Application name. Intentionally left untranslated (a brand name) across locales. -->
    <string name="app_name" translatable="false">Helios</string>

    <!-- Threat-level labels (short names shown on the status panel). -->
    <string name="threat_quiet">Quiet</string>
    <string name="threat_unsettled">Unsettled</string>
    <string name="threat_active">Active</string>
    <string name="threat_storm_minor">Minor Storm</string>
    <string name="threat_storm_moderate">Moderate Storm</string>
    <string name="threat_storm_strong">Strong Storm</string>
    <string name="threat_storm_severe">Severe Storm</string>
    <string name="threat_storm_extreme">Extreme Storm</string>

    <!-- Threat-level descriptions (one human-readable sentence each). -->
    <string name="threat_desc_quiet">Geomagnetic field is calm. No aurora expected at mid-latitudes.</string>
    <string name="threat_desc_unsettled">Slightly unsettled field. Aurora unlikely outside polar regions.</string>
    <string name="threat_desc_active">Active conditions. Aurora possible at high latitudes.</string>
    <string name="threat_desc_storm_minor">Minor geomagnetic storm. Aurora visible at high latitudes; weak power-grid fluctuations.</string>
    <string name="threat_desc_storm_moderate">Moderate storm. Aurora may reach mid-latitudes; possible voltage alarms.</string>
    <string name="threat_desc_storm_strong">Strong storm. Aurora at lower latitudes; satellite and radio disruptions likely.</string>
    <string name="threat_desc_storm_severe">Severe storm. Widespread aurora; power-grid and navigation systems affected.</string>
    <string name="threat_desc_storm_extreme">Extreme storm. Aurora near the equator; major infrastructure impact possible.</string>

    <!-- Dashboard. -->
    <string name="dashboard_title">Helios</string>
    <string name="dashboard_subtitle">Planetary Kp Index</string>
    <string name="unit_kp">KP</string>
    <string name="section_timeline">History &amp; Forecast</string>
    <string name="legend_observed">Observed</string>
    <string name="legend_forecast">Forecast</string>
    <string name="label_now">NOW</string>
    <!-- %1$s = a localized relative time, e.g. "5 minutes ago". -->
    <string name="last_updated">Updated %1$s</string>
    <string name="last_updated_never">Never updated</string>
    <string name="status_loading">Reading space weather…</string>
    <string name="status_offline_cached">Offline — showing last saved data.</string>
    <string name="error_fetch_failed">Couldn\'t reach NOAA. Showing last saved data.</string>
    <string name="empty_no_data">No space-weather data yet.</string>
    <string name="action_retry">Retry</string>
    <string name="cd_refresh">Refresh</string>
    <string name="cd_settings">Settings</string>
    <!-- %1$s = Kp value, %2$s = threat level label. -->
    <string name="cd_gauge">Current Kp index %1$s, %2$s</string>
    <!-- %1$s = Kp value, %2$s = time. -->
    <string name="timeline_readout">Kp %1$s at %2$s</string>

    <!-- Settings. -->
    <string name="settings_title">Settings</string>
    <string name="settings_language_header">Language</string>
    <string name="settings_language_subtitle">Choose the language Helios is displayed in.</string>
    <!-- Language names shown as endonyms; identical in every locale. -->
    <string name="language_english" translatable="false">English</string>
    <string name="language_ukrainian" translatable="false">Українська</string>
    <string name="settings_about_header">About</string>
    <string name="settings_about_body">Helios tracks the NOAA planetary Kp index and warns you about geomagnetic storms.</string>
    <!-- %1$s = version name, e.g. "1.0.0". -->
    <string name="settings_version">Version %1$s</string>
    <string name="cd_back">Back</string>

    <!-- Storm notification + channel. -->
    <string name="storm_channel_name">Geomagnetic Storm Alerts</string>
    <string name="storm_channel_desc">Warnings when the planetary Kp index reaches storm levels (Kp ≥ 5).</string>
    <string name="storm_notification_title">Geomagnetic Storm</string>
    <!-- %1$s = Kp value (e.g. "6.7"), %2$s = threat level (e.g. "Moderate Storm"). -->
    <string name="storm_notification_text">Kp index has reached %1$s — %2$s.</string>
</resources>
