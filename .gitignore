# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Log/OS files
*.log
.DS_Store

# Android Studio / IntelliJ
*.iml
.idea/
captures/
.externalNativeBuild/
.cxx/

# Kotlin
.kotlin/

# Keystore files (never commit signing material)
*.jks
*.keystore

# NOTE: gradle/wrapper/gradle-wrapper.jar is intentionally NOT ignored — it must be
# committed so the project builds on a clean checkout without a local Gradle install.
